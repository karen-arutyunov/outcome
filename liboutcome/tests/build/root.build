# Upstream requires C++ 14 or later.
#
cxx.std = 14

using cxx

hxx{*}: extension = hpp
ixx{*}: extension = ipp
cxx{*}: extension = cpp

# Every exe{} in this subproject is by default a test.
#
exe{*}: test = true

# The test target for cross-testing (running tests under Wine, etc).
#
test.target = $cxx.target
